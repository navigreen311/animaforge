# AnimaForge Environment Variables
# Copy this to .env and fill in real values

# Database
DATABASE_URL=postgresql://animaforge:YOUR_PASSWORD_HERE@localhost:5432/animaforge
REDIS_URL=redis://localhost:6379

# Auth
AUTH0_DOMAIN=YOUR_AUTH0_DOMAIN_HERE
AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID_HERE
AUTH0_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET_HERE
JWT_SECRET=YOUR_JWT_SECRET_HERE

# AWS / Storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY_HERE
S3_BUCKET=animaforge-assets
CLOUDFRONT_DOMAIN=YOUR_CLOUDFRONT_DOMAIN_HERE

# AI Services
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY_HERE

# Stripe Billing
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE
# Price IDs from Stripe Dashboard > Products
STRIPE_PRICE_CREATOR=price_creator_placeholder
STRIPE_PRICE_PRO=price_pro_placeholder
STRIPE_PRICE_STUDIO=price_studio_placeholder
# Portal return URL
BILLING_RETURN_URL=http://localhost:3000/billing

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Kafka
KAFKA_BROKERS=localhost:9092

# App
NODE_ENV=development
PORT=3000
API_PORT=3001
AI_API_PORT=8001
REALTIME_PORT=3002
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_API_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=ws://localhost:3002
